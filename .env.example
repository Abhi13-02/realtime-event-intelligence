# .env.example
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit the .env file to git.
# .env is already in .gitignore — do not remove that entry.

# ─────────────────────────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────────────────────────
# AUTH_SECRET must match the same shared secret used by NextAuth in the frontend.
# FastAPI will use this later to verify the NextAuth JWT signature.
# Generate a strong one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=change-me-generate-with-python-secrets

# Admin panel access key — protects /v1/admin/* routes and the /admin frontend
ADMIN_SECRET_KEY=admin123

# development | production
ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=realtimeintel

# DATABASE_URL is the full connection string used by SQLAlchemy.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/realtimeintel

# ─────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
WEBSOCKET_REDIS_URL=redis://redis:6379/1

# ─────────────────────────────────────────────────────────────────
# KAFKA
# ─────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ─────────────────────────────────────────────────────────────────
# GROQ — used for article summarisation and sub-theme labeling
# ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ─────────────────────────────────────────────────────────────────
# INGESTION (Database-Driven)
# ─────────────────────────────────────────────────────────────────
# Note: Polling intervals and crawl limits are now managed via the 
# Admin Panel at runtime. Static .env overrides are deprecated.
NEWSAPI_KEY=your-newsapi-key
NEWSDATA_KEY=your-newsdata-key

# ─────────────────────────────────────────────────────────────────
# INTELLIGENCE LAYER (sub-theme discovery knobs)
# ─────────────────────────────────────────────────────────────────
# Note: Rolling window size is now managed via the Admin Panel 'System Parameters'
# at runtime. The .env value acts as the default if the DB record is missing.
SUBTHEME_WINDOW_DAYS=3

# Minimum cosine similarity for a Reddit post to be assigned to a
# news-cluster centroid. Lower = more posts match but noisier;
# higher = stricter, fewer assignments. Code default: 0.55.
SUBTHEME_REDDIT_ASSIGN_THRESHOLD=0.55

# ─────────────────────────────────────────────────────────────────
# EXTERNAL APIS
# ─────────────────────────────────────────────────────────────────
# Gemini API — used for topic expansion on the API side

# Twilio — for SMS alert delivery
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ─────────────────────────────────────────────────────────────────
# REDDIT API
# ─────────────────────────────────────────────────────────────────
# Register an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=realtimeintel/1.0 by your-reddit-username

# ─────────────────────────────────────────────────────────────────
# EMAIL (SMTP)
# ─────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=alerts@realtimeintel.com
