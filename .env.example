# .env.example
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit the .env file to git.
# .env is already in .gitignore — do not remove that entry.

# ─────────────────────────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────────────────────────
# AUTH_SECRET must match the same shared secret used by NextAuth in the frontend.
# FastAPI will use this later to verify the NextAuth JWT signature.
# Generate a strong one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=change-me-generate-with-python-secrets

# development | production
ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=realtimeintel

# DATABASE_URL is the full connection string used by SQLAlchemy.
#
# IMPORTANT: The hostname here is 'postgres' — the Docker service name,
# NOT 'localhost'. Inside Docker's internal network, services reach each
# other by service name. From your host machine you would use localhost:5432,
# but your app runs inside Docker, so it uses the service name.
#
# postgresql+asyncpg://  — use the async driver (required for FastAPI's async endpoints)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/realtimeintel

# ─────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────
# Redis has 16 logical databases (db=0 through db=15). We use two:
#   db=0  — Celery task broker (Beat drops tasks here, Worker picks them up)
#   db=1  — WebSocket ticket store (one-time tokens for WS authentication)
# They share the same Redis process but are logically separated.
REDIS_URL=redis://redis:6379/0
WEBSOCKET_REDIS_URL=redis://redis:6379/1

# ─────────────────────────────────────────────────────────────────
# KAFKA
# ─────────────────────────────────────────────────────────────────
# 'kafka:29092' is the internal Docker network port.
# Port 29092 is for communication between Docker services.
# Port 9092 (exposed to host) is for tools running on your machine (e.g., Kafka GUI).
# Your app runs inside Docker, so it uses kafka:29092.
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ─────────────────────────────────────────────────────────────────
# EXTERNAL APIS
# ─────────────────────────────────────────────────────────────────
# Gemini API — used once per article for summarization (not per user)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Twilio — for SMS alert delivery
# Find these in your Twilio Console dashboard
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ─────────────────────────────────────────────────────────────────
# REDDIT API
# ─────────────────────────────────────────────────────────────────
# Register an app at https://www.reddit.com/prefs/apps
# Choose "script" type. Client ID is shown under the app name.
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=realtimeintel/1.0 by your-reddit-username

# ─────────────────────────────────────────────────────────────────
# EMAIL (SMTP)
# ─────────────────────────────────────────────────────────────────
# Used for the 24-hour email digest. For Gmail, use an App Password
# (not your main password) — enable 2FA first, then generate one at:
# Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=alerts@realtimeintel.com
